{
  "name": "Start Dev Server",
  "mode": "sequential",
  "tasks": [
    {
      "task": "shell.exec",
      "args": {
        "command": "npm install"
      }
    },
    {
      "task": "shell.exec",
      "args": {
        "command": "npm run dev -- --host 0.0.0.0 --port 3000"
      }
    }
  ]
}
